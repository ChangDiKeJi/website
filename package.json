{
  "name": "changdi-website",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-files": "node script/copySvgIcons.js",
    "before-build": "npm run copy-files",
    "type-check": "vue-tsc -b",
    "dev": "npm run dev:spa",
    "dev:spa": "cross-env VITE_RENDER_MODE=spa vite",
    "dev:spa-hash": "cross-env VITE_RENDER_MODE=spa-hash vite",
    "dev:ssg": "cross-env VITE_RENDER_MODE=ssg vite",
    "build": "npm run build:ssg",
    "build-only:spa": "cross-env VITE_RENDER_MODE=spa vite build",
    "build-only:spa-hash": "cross-env VITE_RENDER_MODE=spa-hash vite build",
    "build-only:ssg": "cross-env VITE_RENDER_MODE=ssg vite-ssg build",
    "build:spa": "npm run type-check && npm run before-build && npm run build-only:spa",
    "build:spa-hash": "npm run type-check && npm run before-build && npm run build-only:spa-hash",
    "build:ssg": "npm run type-check && npm run before-build && npm run build-only:ssg",
    "build-quick": "npm run build-quick:ssg",
    "build-quick:spa": "npm run type-check && npm run build-only:spa",
    "build-quick:spa-hash": "npm run type-check && npm run build-only:spa-hash",
    "build-quick:ssg": "npm run type-check && npm run build-only:ssg",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "aos": "^2.3.4",
    "bootstrap": "^5.3.8",
    "marked": "^17.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@types/aos": "^3.0.7",
    "@types/bootstrap": "^5.2.10",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "bootstrap-icons": "^1.13.1",
    "cross-env": "^10.1.0",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-ssg": "^28.3.0",
    "vue-tsc": "^3.2.6"
  }
}
